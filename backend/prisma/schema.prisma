// Prisma Schema for Login System
// 用户数据模型 - PostgreSQL 版本

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 用户表
/// 存储用户基本信息和认证凭据
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String?   // bcrypt 加密后的密码，OAuth 用户为空
  githubId            String?   @unique // GitHub OAuth 用户 ID
  githubUsername      String?   // GitHub 用户名
  forcePasswordChange Boolean   @default(false) // 是否强制要求修改密码
  forceChangeReason   String?   // 强制修改原因
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // 关联表
  passwordHistories   PasswordHistory[]
  passwordChangeLogs  PasswordChangeLog[]
  resetTokens         PasswordResetToken[]

  @@index([email])
  @@index([githubId])
}

/// 密码历史表
/// 存储用户最近 5 次密码哈希，用于防止重复使用
model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String   // 历史密码的哈希值
  createdAt    DateTime @default(now())

  @@index([userId])
}

/// 密码修改日志表
/// 审计追踪，记录所有密码修改操作
model PasswordChangeLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  changeType   String   // "manual" | "reset"
  ipAddress    String?  // IP 地址
  userAgent    String?  // 用户代理
  success      Boolean  @default(true) // 是否成功
  errorMessage String?  // 错误信息
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// 密码重置 Token 表
/// 用于忘记密码流程，30 分钟过期
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
